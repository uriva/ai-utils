{
  "name": "@uri/ai-utils",
  "version": "0.1.155",
  "license": "MIT",
  "exports": "./mod.ts",
  "imports": {
    "@google/genai": "npm:@google/genai@1.40.0",
    "@std/assert": "jsr:@std/assert@1.0.14",
    "@uri/inject": "jsr:@uri/inject@0.0.1",
    "gamla": "jsr:@uri/gamla@0.0.6",
    "openai": "npm:openai@5.2.0",
    "zod": "npm:zod@3.25.57"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check *.ts src/**/*.ts tests/**/*.ts",
    "test": "deno test --allow-env --allow-net --allow-read --env=.env --parallel tests/",
    "talk-to-bob": "deno run --allow-env --allow-run --allow-read --allow-write --allow-net --env=.env scripts/talk_to_bob.ts"
  },
  "githooks": {
    "$schema": "https://deno.land/x/githooks/schema.json",
    "pre-commit": "check"
  }
}
